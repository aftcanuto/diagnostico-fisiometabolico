# ============= SUPABASE =============
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# ============= APP =============
NEXT_PUBLIC_APP_NAME="Diagnóstico Fisiometabólico"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============= IA =============
# Configure UMA das duas (Anthropic OU OpenAI). O sistema autodetecta.
# Anthropic é recomendada (laudos clínicos costumam ficar mais precisos).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Alternativa OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
